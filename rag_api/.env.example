# VetrIAge RAG System Environment Variables
# Copy this file to .env and fill in your API keys

# Required: PubMed API (free, get from https://www.ncbi.nlm.nih.gov/account/)
NCBI_API_KEY=your_ncbi_api_key_here
NCBI_EMAIL=your_email@example.com

# Required: OpenAI API (for embeddings)
OPENAI_API_KEY=sk-your_openai_key_here

# Option A (RECOMMENDED): OpenRouter API (access multiple LLMs with one key)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Option B: Anthropic API direct (fallback if OpenRouter not set)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# Server Configuration (Flexible Port System)
PORT=8000                    # Default port, override with: PORT=9000 python ...
HOST=0.0.0.0                # Bind address (0.0.0.0 for all interfaces)

# Optional: Model Configuration
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=anthropic/claude-3.5-sonnet
MAX_PAPERS_PER_QUERY=10
VECTOR_STORE_TYPE=faiss

# Optional: PostgreSQL (if using pgvector)
# POSTGRES_CONNECTION_STRING=postgresql://user:pass@localhost:5432/vetriage
