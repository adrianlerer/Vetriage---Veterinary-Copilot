{
  "buildCommand": "cd pwa && npm install && npm run build",
  "outputDirectory": "pwa/dist",
  "framework": null,
  "functions": {
    "api/*.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
